# Maintainer: KilimcininKorOglu <KilimcininKorOglu>
pkgname=desmos
pkgver=0.1.0
pkgrel=1
pkgdesc='Cross-platform connection bonding VPN'
arch=('x86_64' 'aarch64')
url='https://github.com/KilimcininKorOglu/desmos'
license=('MIT')
depends=()
makedepends=('cargo' 'rust>=1.75')
source=("$pkgname-$pkgver.tar.gz::https://github.com/KilimcininKorOglu/desmos/archive/v$pkgver.tar.gz")
sha256sums=('SKIP')

build() {
    cd "$pkgname-$pkgver"
    export RUSTUP_TOOLCHAIN=stable
    export CARGO_TARGET_DIR=target
    cargo build --release --locked
}

check() {
    cd "$pkgname-$pkgver"
    export RUSTUP_TOOLCHAIN=stable
    export CARGO_TARGET_DIR=target
    cargo test --release --locked
}

package() {
    cd "$pkgname-$pkgver"
    install -Dm755 "target/release/desmos" "$pkgdir/usr/bin/desmos"
    install -Dm644 "packaging/linux/systemd/desmos.service" "$pkgdir/usr/lib/systemd/system/desmos.service"
    install -Dm644 "LICENSE" "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
    install -Dm644 "README.md" "$pkgdir/usr/share/doc/$pkgname/README.md"
    install -dm700 "$pkgdir/etc/desmos"
}
